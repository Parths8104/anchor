# Required: your OpenAI API key
OPENAI_API_KEY=sk-...

# LLM settings
ANCHOR_GENERATION_MODEL=gpt-4o-mini
ANCHOR_EMBEDDING_MODEL=text-embedding-3-small
ANCHOR_JUDGE_MODEL=gpt-4o-mini

# Chunking
ANCHOR_CHUNK_TOKENS=512
ANCHOR_CHUNK_OVERLAP_TOKENS=64

# Retrieval
ANCHOR_RETRIEVAL_TOP_K=10
ANCHOR_RERANK_TOP_K=4
ANCHOR_DENSE_WEIGHT=0.5

# Storage
ANCHOR_VECTOR_DB_PATH=./.chroma
ANCHOR_BM25_INDEX_PATH=./.bm25.pkl

# Logging
ANCHOR_LOG_LEVEL=INFO
